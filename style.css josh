/* =============================================
   Joshua Attipoe — Personal Profile Stylesheet
   ============================================= */

/* --- Google Fonts are loaded in HTML --- */

/* --- CSS Variables --- */
:root {
      --bg:        #0d0d0d;
      --surface:   #161616;
      --border:    #2a2a2a;
      --text:      #e8e2d9;
      --muted:     #7a7570;
      --accent:    #c8a96e;       /* warm gold */
      --accent2:   #4e8c6e;       /* sage green */
      --heading-font: 'Playfair Display', Georgia, serif;
      --body-font:    'DM Sans', sans-serif;
    }
    
    /* --- Reset & Base --- */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    
    html { scroll-behavior: smooth; }
    
    body {
      background-color: var(--bg);
      color: var(--text);
      font-family: var(--body-font);
      font-weight: 300;
      line-height: 1.7;
      font-size: 16px;
      overflow-x: hidden;
    }
    
    /* --- Noise Texture Overlay --- */
    .noise {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 999;
      opacity: 0.035;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 180px;
    }
    
    /* --- Header --- */
    header {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 6rem 2rem 4rem;
      overflow: hidden;
      background: radial-gradient(ellipse 80% 60% at 60% 40%, #1e1a13 0%, var(--bg) 70%);
    }
    
    .header-inner {
      max-width: 700px;
      margin: 0 auto;
      position: relative;
      z-index: 2;
      animation: fadeUp 0.9s ease both;
    }
    
    .label {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.5rem;
    }
    
    header h1 {
      font-family: var(--heading-font);
      font-size: clamp(3.5rem, 10vw, 7rem);
      font-weight: 900;
      line-height: 1;
      color: var(--text);
      margin-bottom: 1.5rem;
      letter-spacing: -0.02em;
    }
    
    header h1 .accent {
      color: var(--accent);
      font-style: italic;
    }
    
    .tagline {
      font-size: 1rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
    }
    
    /* Decorative circle */
    .header-shape {
      position: absolute;
      right: -120px;
      top: 50%;
      transform: translateY(-50%);
      width: 520px;
      height: 520px;
      border-radius: 50%;
      border: 1px solid var(--border);
      z-index: 1;
      animation: spin 60s linear infinite;
    }
    .header-shape::after {
      content: '';
      position: absolute;
      top: 30px; left: 30px; right: 30px; bottom: 30px;
      border-radius: 50%;
      border: 1px dashed var(--accent);
      opacity: 0.3;
    }
    
    /* --- Main Content --- */
    main {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 2rem 6rem;
    }
    
    section {
      padding: 5rem 0;
      border-top: 1px solid var(--border);
    }
    
    /* Section label */
    .section-label {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent2);
      margin-bottom: 2.5rem;
    }
    
    /* --- About Section --- */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 3rem;
      align-items: start;
    }
    
    .about-text p {
      font-size: 1.05rem;
      color: var(--text);
      margin-bottom: 1.25rem;
      max-width: 520px;
    }
    
    .about-text strong { color: var(--accent); font-weight: 500; }
    
    /* Profile card */
    .about-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 2rem 1.5rem;
      text-align: center;
      min-width: 170px;
      flex-shrink: 0;
    }
    
    .initials {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--heading-font);
      font-size: 1.6rem;
      font-weight: 700;
      color: #0d0d0d;
      margin: 0 auto 1rem;
    }
    
    .card-name {
      font-weight: 500;
      font-size: 0.95rem;
      color: var(--text);
    }
    
    .card-role {
      font-size: 0.8rem;
      color: var(--muted);
      margin-top: 0.3rem;
    }
    
    /* --- Skills Section --- */
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1.25rem;
    }
    
    .skill-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.75rem;
      transition: border-color 0.2s, transform 0.2s;
    }
    
    .skill-card:hover {
      border-color: var(--accent);
      transform: translateY(-3px);
    }
    
    .skill-icon {
      font-size: 1.6rem;
      display: block;
      margin-bottom: 0.75rem;
    }
    
    .skill-card h3 {
      font-family: var(--heading-font);
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 0.5rem;
    }
    
    .skill-card p {
      font-size: 0.88rem;
      color: var(--muted);
      line-height: 1.6;
    }
    
    /* --- Contact Section --- */
    .contact {
      text-align: center;
    }
    
    .contact h2 {
      font-family: var(--heading-font);
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 900;
      color: var(--text);
      margin-bottom: 1rem;
    }
    
    .contact > p {
      color: var(--muted);
      font-size: 1rem;
      margin-bottom: 2.5rem;
    }
    
    .email-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: linear-gradient(135deg, var(--accent), #e0c080);
      color: #0d0d0d;
      font-family: var(--body-font);
      font-weight: 500;
      font-size: 1rem;
      padding: 1rem 2.2rem;
      border-radius: 50px;
      text-decoration: none;
      transition: opacity 0.2s, transform 0.2s;
      letter-spacing: 0.02em;
    }
    
    .email-btn:hover {
      opacity: 0.88;
      transform: scale(1.03);
    }
    
    /* --- Footer --- */
    footer {
      border-top: 1px solid var(--border);
      text-align: center;
      padding: 2rem;
      font-size: 0.82rem;
      color: var(--muted);
    }
    
    footer strong { color: var(--accent); }
    
    /* --- Animations --- */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(28px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    
    @keyframes spin {
      from { transform: translateY(-50%) rotate(0deg); }
      to   { transform: translateY(-50%) rotate(360deg); }
    }
    
    /* --- Responsive --- */
    @media (max-width: 640px) {
      .about-grid {
        grid-template-columns: 1fr;
      }
      .about-card {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        text-align: left;
      }
      .initials { margin: 0; flex-shrink: 0; }
      .header-shape { display: none; }
    }